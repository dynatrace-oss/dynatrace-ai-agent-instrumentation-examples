{"version":21,"variables":[],"tiles":{"header-logo":{"type":"markdown","content":"![](https://upload.wikimedia.org/wikipedia/commons/thumb/4/4d/OpenAI_Logo.svg/1280px-OpenAI_Logo.svg.png)\n"},"header-exec-summary":{"type":"markdown","content":"## OPENAI CODEX CLI MONITORING\nMonitors API requests, tool calls, latency, and session activity from [OpenAI Codex CLI](https://github.com/openai/codex) sessions using its built-in OpenTelemetry support — no code changes required.\n\nEnable telemetry by configuring the `[otel]` section in `~/.codex/config.toml` with your Dynatrace OTLP endpoint before running `codex`.\n\nFor full setup instructions, see the [GitHub example](https://github.com/dynatrace-oss/dynatrace-ai-agent-instrumentation-examples/tree/main/openai-codex)."},"kpi-total-conversations":{"title":"Total Conversations","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.conversation_starts\"\n| summarize TotalConversations = count()","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"Conversations","recordField":"TotalConversations","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"kpi-total-api-requests":{"title":"Total API Requests","type":"data","query":"timeseries requests = sum(`codex.api_request`)\n| fieldsAdd TotalRequests = arraySum(requests)","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"API Requests","recordField":"TotalRequests","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"kpi-total-tool-calls":{"title":"Total Tool Calls","type":"data","query":"timeseries calls = sum(`codex.tool.call`)\n| fieldsAdd TotalToolCalls = arraySum(calls)","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"Tool Calls","recordField":"TotalToolCalls","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"kpi-avg-api-latency":{"title":"Avg API Latency (ms)","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.api_request\"\n| summarize AvgLatency = avg(toLong(duration_ms))","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"Avg Latency ms","recordField":"AvgLatency","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-trends":{"type":"markdown","content":"## TRENDS"},"chart-api-requests-over-time":{"title":"API Requests Over Time","type":"data","query":"timeseries requests = sum(`codex.api_request`)","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-tool-calls-over-time":{"title":"Tool Calls Over Time","type":"data","query":"timeseries calls = sum(`codex.tool.call`), by: {tool_name}","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-event-volume-over-time":{"title":"Event Volume by Type","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\"\n| makeTimeseries count = count(), by: {`event.name`}","visualization":"areaChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-api-analytics":{"type":"markdown","content":"## API REQUEST ANALYTICS"},"chart-api-latency-over-time":{"title":"API Latency Over Time (ms)","type":"data","query":"timeseries avg_latency = avg(`codex.api_request.duration_ms`)","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-ttft-over-time":{"title":"Time to First Token (ms)","type":"data","query":"timeseries ttft = avg(`codex.responses_api_engine_service_ttft.duration_ms`)","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-inference-time":{"title":"Inference Time vs Overhead (ms)","type":"data","query":"timeseries inference = avg(`codex.responses_api_inference_time.duration_ms`), overhead = avg(`codex.responses_api_overhead.duration_ms`)","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-tokens-by-model":{"title":"Token Usage by Model","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.api_request\"\n| summarize\n    input_tokens = sum(toLong(input_tokens)),\n    output_tokens = sum(toLong(output_tokens)),\n    by: {model}\n| sort input_tokens desc","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"chartSettings":{"categoricalBarChartSettings":{"categoryAxis":["model"],"valueAxis":["input_tokens","output_tokens"]},"legend":{"position":"bottom"}},"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"blue-sky"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-requests-by-model":{"title":"API Requests by Model","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.api_request\"\n| summarize count = count(), by: {model}\n| sort count desc","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"right"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-tool-usage":{"type":"markdown","content":"## TOOL USAGE"},"chart-most-used-tools":{"title":"Most Used Tools","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.tool_result\"\n| summarize count = count(), by: {tool_name}\n| sort count desc","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"chartSettings":{"legend":{"position":"bottom"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-avg-tool-duration":{"title":"Avg Tool Duration (ms)","type":"data","query":"timeseries avg_duration = avg(`codex.tool.call.duration_ms`), by: {tool_name}","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"chartSettings":{"legend":{"position":"bottom"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"pie-tool-decision-source":{"title":"Tool Decision Source","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.tool_decision\"\n| summarize count = count(), by: {decision_source}","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"pie-tool-decision":{"title":"Tool Decisions (Approved vs Rejected)","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.tool_decision\"\n| summarize count = count(), by: {decision}","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"pie-tool-success":{"title":"Tool Success Rate","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.tool_result\"\n| fieldsAdd result = if(success == \"true\", then:\"Success\", else:\"Failure\")\n| summarize count = count(), by: {result}","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-conversations":{"type":"markdown","content":"## CONVERSATION ANALYTICS"},"chart-conversations-by-model":{"title":"Conversations by Model","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.conversation_starts\"\n| summarize count = count(), by: {model}\n| sort count desc","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"chartSettings":{"legend":{"position":"bottom"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-conversations-by-approval-policy":{"title":"Conversations by Approval Policy","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.conversation_starts\"\n| summarize count = count(), by: {approval_policy}\n| sort count desc","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"right"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-conversations-by-session-source":{"title":"Conversations by Session Source","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.conversation_starts\"\n| summarize count = count(), by: {session_source}\n| sort count desc","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"right"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"blue-sky","comparator":"= *value*","field":"DT.name","type":"string","value":""}]},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-avg-tokens-per-request":{"title":"Avg Tokens per Request","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.api_request\"\n| fieldsAdd total_tokens = toLong(input_tokens) + toLong(output_tokens)\n| summarize AvgTokens = avg(total_tokens)","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"Avg Tokens","recordField":"AvgTokens","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-tool-calls-per-conversation":{"title":"Avg Tool Calls per Conversation","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\" and `event.name` == \"codex.tool_result\"\n| summarize tool_calls = count(), by: {`conversation.id`}\n| summarize AvgToolCalls = avg(tool_calls)","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"Avg Tool Calls","recordField":"AvgToolCalls","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-event-stream":{"type":"markdown","content":"## EVENT STREAM\n\n**Note:** Prompt content is redacted by default. Set `log_user_prompt = true` in `~/.codex/config.toml` under `[otel]` to include user prompts in log events."},"table-live-event-feed":{"title":"Live Event Feed","type":"data","query":"fetch logs\n| filter `service.name` == \"codex_cli_rs\"\n| fields timestamp, `event.name`, `conversation.id`, tool_name, model, originator, duration_ms, input_tokens, output_tokens, decision, success\n| sort timestamp desc\n| limit 50","visualization":"table","visualizationSettings":{"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}}},"layouts":{"header-logo":{"x":0,"y":0,"w":4,"h":5},"header-exec-summary":{"x":4,"y":0,"w":20,"h":5},"kpi-total-conversations":{"x":0,"y":5,"w":6,"h":4},"kpi-total-api-requests":{"x":6,"y":5,"w":6,"h":4},"kpi-total-tool-calls":{"x":12,"y":5,"w":6,"h":4},"kpi-avg-api-latency":{"x":18,"y":5,"w":6,"h":4},"