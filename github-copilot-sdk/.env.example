# GitHub Copilot SDK authentication
GH_TOKEN=ghp_your_github_token_here

# Dynatrace OTLP ingestion
# OTLP base path: classic domain + /api/v2/otlp
# See: https://docs.dynatrace.com/docs/ingest-from/opentelemetry/otlp-api
# Token requires scopes: openTelemetryTrace.ingest, metrics.ingest (classic token dt0c01.*)
DYNATRACE_OTLP_URL=https://YOUR_ENV_ID.live.dynatrace.com/api/v2/otlp
DYNATRACE_OTLP_TOKEN=dt0c01.YOUR_TOKEN_HERE

# Optional: service name for traces/metrics (default: copilot-sdk-agent)
# OTEL_SERVICE_NAME=copilot-sdk-agent

# Optional: capture prompt/completion content in spans (default: false)
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
