{
    "version": 21,
    "variables": [],
    "tiles": {
        "1": {
            "type": "markdown",
            "content": "![](https://github.githubassets.com/favicons/favicon.svg)\n"
        },
        "2": {
            "type": "markdown",
            "content": "### AI Observability\n\nEnd-to-end observability for GitHub Copilot SDK agents.\nMonitor LLM calls, token usage, tool execution, latency and cost."
        },
        "3": {
            "type": "markdown",
            "content": " ### Service Health & Performance"
        },
        "10": {
            "title": "Open Problems",
            "type": "data",
            "query": "fetch dt.davis.problems\n| filter event.status == \"ACTIVE\" and dt.entity.service != \"\"\n| fieldsKeep dt.entity.service, event.id\n| expand dt.entity.service\n| lookup sourceField:dt.entity.service, lookupField:dt.entity.service, prefix:\"gen_ai.\", [\n  fetch spans | filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"}) | fields dt.entity.service, name = entity.name\n]\n| filter gen_ai.dt.entity.service != \"\"\n| summarize {problemCount = countDistinct(event.id)}",
            "visualization": "singleValue",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "singleValue": {
                    "labelMode": "none",
                    "label": "problemCount",
                    "recordField": "problemCount",
                    "sparklineSettings": { "isVisible": false },
                    "trend": { "isVisible": false }
                },
                "thresholds": [
                    {
                        "id": 1,
                        "field": "problemCount",
                        "isEnabled": true,
                        "rules": [
                            { "id": 0, "color": { "Default": "var(--dt-colors-charts-status-ideal-default, #2f6863)" }, "comparator": "=", "value": 0 },
                            { "id": 1, "color": { "Default": "var(--dt-colors-charts-status-warning-default, #eca440)" }, "comparator": ">", "value": 0 },
                            { "id": 2, "color": { "Default": "var(--dt-colors-charts-status-critical-default, #c4233b)" }, "comparator": "≥", "value": 5 }
                        ]
                    }
                ],
                "unitsOverrides": [
                    { "identifier": "problemCount", "unitCategory": "unspecified", "baseUnit": "none", "displayUnit": null, "decimals": 0, "suffix": "", "delimiter": false, "added": 1729071009406 }
                ]
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 100, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "11": {
            "title": "# of Total LLM Requests",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| summarize requestCount = count()",
            "visualization": "singleValue",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "singleValue": {
                    "labelMode": "none",
                    "label": "requestCount",
                    "recordField": "requestCount",
                    "sparklineSettings": { "isVisible": false },
                    "trend": { "isVisible": false }
                }
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "12": {
            "title": "Estimated Cost",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd inputTokens = toDouble(gen_ai.usage.input_tokens)\n| fieldsAdd outputTokens = toDouble(gen_ai.usage.output_tokens)\n| summarize {\n  totalInput = sum(inputTokens),\n  totalOutput = sum(outputTokens)\n}\n| fieldsAdd cost = (totalInput * 0.003 + totalOutput * 0.015) / 1000",
            "visualization": "singleValue",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "singleValue": {
                    "labelMode": "none",
                    "label": "cost",
                    "recordField": "cost",
                    "sparklineSettings": { "isVisible": false },
                    "trend": { "isVisible": false }
                },
                "unitsOverrides": [
                    { "identifier": "cost", "unitCategory": "currency", "baseUnit": "usd", "displayUnit": null, "decimals": 4, "suffix": "$", "delimiter": true, "added": 1727163553354 }
                ]
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "13": {
            "title": "Service Health",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd hasError = if(status == \"ERROR\", then:1, else:0)\n| summarize {\n  success = countIf(hasError == 0),\n  error = countIf(hasError == 1)\n}",
            "visualization": "pieChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "chartSettings": {
                    "circleChartSettings": { "groupingThresholdType": "relative", "groupingThresholdValue": 0, "valueType": "relative" }
                }
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "14": {
            "title": "P99 Request Duration",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd durationNs = end_time - start_time\n| summarize p99 = percentile(durationNs, 99)",
            "visualization": "singleValue",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "singleValue": {
                    "labelMode": "none",
                    "label": "p99",
                    "recordField": "p99",
                    "sparklineSettings": { "isVisible": false },
                    "trend": { "isVisible": false }
                },
                "unitsOverrides": [
                    { "identifier": "p99", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": 1, "suffix": "", "delimiter": false, "added": 1729071009406 }
                ]
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "15": {
            "title": "AVG Request Duration",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd durationNs = end_time - start_time\n| summarize avgDuration = avg(durationNs)",
            "visualization": "singleValue",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "singleValue": {
                    "labelMode": "none",
                    "label": "avgDuration",
                    "recordField": "avgDuration",
                    "sparklineSettings": { "isVisible": false },
