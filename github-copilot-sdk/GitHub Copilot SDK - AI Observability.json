                "unitsOverrides": [
                    { "identifier": "avgDuration", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": 1, "suffix": "", "delimiter": false, "added": 1729071009406 }
                ]
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "16": {
            "title": "LLM Request Duration Over Time",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd durationNs = end_time - start_time\n| makeTimeseries avg_duration = avg(durationNs), p99_duration = percentile(durationNs, 99), interval:5m",
            "visualization": "lineChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "chartSettings": {
                    "xAxisScaling": "analyzedTimeframe",
                    "gapPolicy": "gap",
                    "curve": "linear"
                }
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "20": {
            "type": "markdown",
            "content": "---\n### Tool Execution"
        },
        "21": {
            "title": "Tool Executions by Name",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND gen_ai.operation.name == \"execute_tool\"\n| fieldsAdd toolName = gen_ai.tool.name\n| summarize count = count(), by:{toolName}\n| sort count desc",
            "visualization": "categoricalBarChart",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "chartSettings": {
                    "categoricalBarChartSettings": {
                        "layout": "horizontal",
                        "categoryAxisTickLayout": "horizontal",
                        "scale": "absolute",
                        "groupMode": "stacked",
                        "colorPaletteMode": "multi-color",
                        "categoryAxisLabel": "toolName",
                        "valueAxisLabel": "count",
                        "categoryAxis": ["toolName"],
                        "valueAxis": ["count"]
                    }
                }
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "22": {
            "title": "Tool Error Rate",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND gen_ai.operation.name == \"execute_tool\"\n| summarize {\n  total = count(),\n  errors = countIf(status == \"ERROR\")\n}\n| fieldsAdd errorRate = 100.0 * errors / total",
            "visualization": "singleValue",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "singleValue": {
                    "labelMode": "none",
                    "label": "errorRate",
                    "recordField": "errorRate",
                    "sparklineSettings": { "isVisible": false },
                    "trend": { "isVisible": false }
                },
                "thresholds": [
                    {
                        "id": 1,
                        "field": "errorRate",
                        "isEnabled": true,
                        "rules": [
                            { "id": 0, "color": { "Default": "var(--dt-colors-charts-status-ideal-default, #2f6863)" }, "comparator": "<=", "value": 5 },
                            { "id": 1, "color": { "Default": "var(--dt-colors-charts-status-warning-default, #eca440)" }, "comparator": "<=", "value": 20 },
                            { "id": 2, "color": { "Default": "var(--dt-colors-charts-status-critical-default, #c4233b)" }, "comparator": ">", "value": 20 }
                        ]
                    }
                ],
                "unitsOverrides": [
                    { "identifier": "errorRate", "unitCategory": "percentage", "baseUnit": "percent", "displayUnit": null, "decimals": 1, "suffix": "", "delimiter": false, "added": 1736408978529 }
                ]
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "23": {
            "title": "Total Tool Calls",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND gen_ai.operation.name == \"execute_tool\"\n| summarize toolCalls = count()",
            "visualization": "singleValue",
