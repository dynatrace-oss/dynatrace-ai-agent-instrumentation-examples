        "41": {
            "title": "Top 10 Expensive Prompts",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd inputTokens = toDouble(coalesce(gen_ai.usage.input_tokens, \"0\"))\n| fieldsAdd outputTokens = toDouble(coalesce(gen_ai.usage.output_tokens, \"0\"))\n| fieldsAdd tokens = inputTokens + outputTokens\n| fieldsAdd cost = (inputTokens * 0.003 + outputTokens * 0.015) / 1000\n| fieldsAdd model = gen_ai.request.model\n| fieldsAdd prompt = gen_ai.prompt.0.content\n| fieldsAdd response = gen_ai.completion.0.content\n| sort tokens desc\n| fields trace.id, model, tokens, cost, prompt, response\n| limit 10",
            "visualization": "table",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "table": {
                    "columnTypeOverrides": [
                        { "id": 1, "fields": ["prompt", "response"], "value": "text" }
                    ],
                    "lineWrapIds": [["prompt"], ["response"]],
                    "columnWidths": { "[\"response\"]": 500 }
                },
                "unitsOverrides": [
                    { "identifier": "cost", "unitCategory": "currency", "baseUnit": "usd", "displayUnit": null, "decimals": 4, "suffix": "", "delimiter": false, "added": 1736932856141 }
                ]
            },
            "querySettings": { "maxResultRecords": 1000, "defaultScanLimitGbytes": 500, "maxResultMegaBytes": 1, "defaultSamplingRatio": 10, "enableSampling": false },
            "davis": { "enabled": false, "davisVisualization": { "isAvailable": true } }
        },
        "42": {
            "title": "Top 10 Slowest Prompts",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd durationNs = end_time - start_time\n| fieldsAdd model = gen_ai.request.model\n| fieldsAdd tokens = toDouble(coalesce(gen_ai.usage.input_tokens, \"0\")) + toDouble(coalesce(gen_ai.usage.output_tokens, \"0\"))\n| fieldsAdd prompt = gen_ai.prompt.0.content\n| fieldsAdd response = gen_ai.completion.0.content\n| sort durationNs desc\n| fields trace.id, model, durationNs, tokens, prompt, response\n| limit 10",
            "visualization": "table",
            "visualizationSettings": {
                "autoSelectVisualization": false,
                "table": {
                    "columnTypeOverrides": [
                        { "id": 1, "fields": ["prompt", "response"], "value": "text" }
                    ],
                    "lineWrapIds": [["prompt"], ["response"]],
                    "columnWidths": { "[\"response\"]": 500 }
                },
                "unitsOverrides": [
