        "35": {
            "title": "Cost by Model",
            "type": "data",
            "query": "fetch spans\n| filter isNotNull(gen_ai.provider.name) AND in(llm.request.type, {\"chat\", \"completion\"})\n| fieldsAdd model = gen_ai.request.model\n| fieldsAdd inputTokens = toDouble(gen_ai.usage.input_tokens)\n| fieldsAdd outputTokens = toDouble(gen_ai.usage.output_tokens)\n| summarize {\n  prompt = sum(inputTokens),\n  completion = sum(outputTokens),\n  requests = count()\n}, by:{model}\n| fieldsAdd cost = (prompt * 0.003 + completion * 0.015) / 1000\n| sort cost desc",
