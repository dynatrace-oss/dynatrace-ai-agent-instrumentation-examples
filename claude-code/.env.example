# Dynatrace OTLP configuration for Claude Code telemetry
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Dynatrace API token with openTelemetryTrace.ingest scope
DT_API_TOKEN=dt0c01.XXXXXXXX.XXXXXXXXXXXXXXXX

# Dynatrace OTLP endpoint (base URL, do NOT include /v1/traces or other signal suffixes)
# SaaS production:  https://<env-id>.live.dynatrace.com/api/v2/otlp
# Dev / Preview:    https://<env-id>.dev.dynatracelabs.com/api/v2/otlp
DT_OTEL_ENDPOINT=https://<YOUR_ENV_ID>.live.dynatrace.com/api/v2/otlp
