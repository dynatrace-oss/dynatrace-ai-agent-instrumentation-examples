# Copy to .env and fill in values
export TRACELOOP_TRACE_CONTENT=true
export LITELLM_LOG=DEBUG
ANTHROPIC_API_KEY=sk-ant-...
export UI_USERNAME=admin   # username to sign in on UI
export UI_PASSWORD=litellm # password to sign in on UI
export PROXY_ADMIN_ID=admin

# LiteLLM proxy master key (used for all API calls and Admin UI access)
export LITELLM_MASTER_KEY=sk-admin-local

# Admin UI credentials (simulated SSO login)
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=admin123