# Dynatrace OTLP ingest endpoint (base URL — no /v1/traces suffix)
# SaaS:    https://<env-id>.live.dynatrace.com/api/v2/otlp
DT_OTEL_ENDPOINT=https://<YOUR_ENV_ID>.live.dynatrace.com/api/v2/otlp

# Dynatrace API token — required scopes: openTelemetryTrace.ingest, logs.ingest
DT_API_TOKEN=<YOUR_DT_TOKEN>
