{"version":21,"variables":[],"tiles":{"0":{"type":"markdown","content":"![](https://dt-cdn.net/images/claude-code-3564-3e987efe22.png)"},"1":{"title":"Total Users","type":"data","query":"fetch logs\n| filter service.name == \"claude-code\"\n| summarize TotalUsers = countDistinct(`user.id`)","visualization":"singleValue","visualizationSettings":{"autoSelectVisualization":false,"singleValue":{"label":"Users","recordField":"TotalUsers"}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"2":{"title":"Lines of Code Added","type":"data","query":"timeseries lines = sum(`claude_code.lines_of_code.count`), by: {type}\n| filter type == \"added\"\n| summarize LinesAdded = sum(arraySum(lines))","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"LinesAdded","recordField":"LinesAdded"},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"3":{"title":"Lines of Code Removed","type":"data","query":"timeseries lines = sum(`claude_code.lines_of_code.count`), by: {type}\n| filter type == \"removed\"\n| summarize LinesRemoved = sum(arraySum(lines))","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"LinesRemoved","recordField":"LinesRemoved"},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"4":{"title":"Git Commits","type":"data","query":"timeseries commits = sum(`claude_code.commit.count`)\n| summarize TotalCommits = sum(arraySum(commits))","visualization":"singleValue","visualizati