*value*","value":"","colorMode":"color-palette","colorPalette":"fireplace"}]},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"8":{"type":"markdown","content":"## ENGINEERING METRICS"},"9":{"title":"Avg Active Time per Session (s)","type":"data","query":"timeseries activeTime = sum(`claude_code.active_time.total`), by: {`session.id`}\n| summarize total = sum(arraySum(activeTime)), sessions = count()\n| fieldsAdd AvgSessionTime = total / sessions\n| fields AvgSessionTime","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"AvgSessionTime","recordField":"AvgSessionTime"},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"10":{"title":"Avg Tokens per Request","type":"data","query":"fetch logs\n| filter `service.name` == \"claude-code\" and `event.name` == \"api_request\"\n| fieldsAdd total_tokens = toLong(input_tokens) + toLong(output_tokens)\n| summarize AvgTokensPerRequest = avg(total_tokens)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"AvgTokensPerRequest","recordField":"AvgTokensPerRequest"},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"11":{"title":"Avg Cost per Session (USD)","type":"data","query":"fetch logs\n| filter `service.name` == \"claude-code\" and `event.name` == \"api_request\"\n| fieldsAdd cost = toDouble(cost_usd)\n| summarize total = sum(cost), by: {`session.id`}\n| summarize AvgCostPerSession = avg(total)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"AvgCostPerSession","recordField":"AvgCostPerSession"},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"12":{"title":"Cost by Speed Mode","type":"data","query":"fetch logs\n| filter `service.name` == \"claude-code\" and `event.name` == \"api_request\"\n| summarize cost = sum(toDouble(cost_usd)), by: {speed}","visualization":"categoricalBarChart","visualizationSettings":{"autoSelectVisualization":false,"chartSettings":{"legend":{"position":"bottom"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"purple-rain","comparator":"= *value*","field":"DT.name","type":"string","value":""}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-exec-summary":{"type":"markdown","content":"## ANTHROPIC CLAUDE CODE MONITORING\nMonitors cost, token usage, sessions, and tool activity from [Claude Code](https://code.claude.com) CLI sessions using its built-in OpenTelemetry support — no code changes required. \n\nEnable telemetry by setting `CLAUDE_CODE_ENABLE_TELEMETRY=1` and pointing the OTLP exporter to your Dynatrace environment before running `claude`.\n\nFor full setup instructions, see the [GitHub example](https://github.com/dynatrace-oss/dynatrace-ai-agent-instrumentation-examples/tree/main/claude-code) or the [Claude Code monitoring docs](https://code.claude.com/docs/en/monitoring-usage)."},"kpi-total-cost":{"title":"Total Cost (USD)","type":"data","query":"timeseries cost = sum(`claude_code.cost.usage`)\n| fieldsAdd Cost = arraySum(cost)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"Cost","recordField":"Cost","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"kpi-total-tokens":{"title":"Total Tokens","type":"data","query":"timeseries tokens = sum(`claude_code.token.usage`)\n| fieldsAdd Tokens = arraySum(tokens)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"Tokens","recordField":"Tokens","sparklineSettings":{"isVisible":false},"trend":{"isVisible":false}},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"kpi-total-sessions":{"title":"Total Sessions","type":"data","query":"timeseries sessions = sum(`claude_code.session.count`)\n| fieldsAdd TotalSessions = arraySum(sessions)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"TotalSessions","recordField":"TotalSessions","trend":{"isVisible":false},"sparklineSettings":{"isVisible":false}},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"kpi-active-time":{"title":"Active Time","type":"data","query":"timeseries activeTime = sum(`claude_code.active_time.total`)\n| fieldsAdd ActiveTime = arraySum(activeTime)","visualization":"singleValue","visualizationSettings":{"singleValue":{"label":"ActiveTime","recordField":"ActiveTime","sparklineSettings":{"isVisible":false},"trend":{"isVisible":false}},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-trends":{"type":"markdown","content":"## TRENDS AND COST BREAKDOWN"},"chart-cost-over-time":{"title":"Cost Over Time","type":"data","query":"timeseries CostOverTime = sum(`claude_code.cost.usage`)","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"purple-rain"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-token-usage-over-time":{"title":"Token Usage Over Time","type":"data","query":"timeseries TokenUsageOverTime = sum(`claude_code.token.usage`)","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"purple-rain"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"header-api-analytics":{"type":"markdown","content":"## API REQUEST ANALYTICS"},"chart-cost-by-model":{"title":"Cost by Model","type":"data","query":"timeseries cost = sum(`claude_code.cost.usage`), by: {model}\n| summarize totalCost = sum(arraySum(cost)), by: {model}\n| sort totalCost desc","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"right"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"purple-rain","comparator":"= *value*","field":"DT.name","type":"string","value":""}]},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"table-token-cost-by-model":{"title":"Token & Cost Breakdown by Model","type":"data","query":"fetch logs\n| filter `service.name` == \"claude-code\" and `event.name` == \"api_request\"\n| summarize\n    total_input = sum(toLong(input_tokens)),\n    total_output = sum(toLong(output_tokens)),\n    total_cache_read = sum(toLong(cache_read_tokens)),\n    total_cache_creation = sum(toLong(cache_creation_tokens)),\n    total_cost_usd = sum(toDouble(cost_usd)),\n    by: {model}\n| sort total_cost_usd desc","visualization":"pieChart","visualizationSettings":{"chartSettings":{"legend":{"position":"right"}},"coloring":{"colorRules":[{"colorMode":"color-palette","colorPalette":"purple-rain","comparator":"= *value*","field":"DT.name","type":"string","value":""}]},"autoSelectVisualization":false},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":{"enabled":false,"davisVisualization":{"isAvailable":true}}},"chart-api-latency":{"title":"API Latency Over Time","type":"data","query":"fetch logs\n| filter `service.name` == \"claude-code\" and `event.name` == \"api_request\"\n| makeTimeseries avg_duration = avg(toLong(duration_ms))","visualization":"lineChart","visualizationSettings":{"chartSettings":{"legend":{"position":"bottom"}},"autoSelectVisualization":false,"coloring":{"colorRules":[{"field":"DT.name","type":"string","comparator":"= *value*","value":"","colorMode":"color-palette","colorPalette":"purple-rain"}]}},"querySettings":{"maxResultRecords":1000,"defaultScanLimitGbytes":500,"maxResultMegaBytes":100,"defaultSamplingRatio":10,"enableSampling":false},"davis":