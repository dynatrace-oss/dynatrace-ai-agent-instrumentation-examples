# Dynatrace tenant (classic URL — used by OTel collector in make run)
DT_ENDPOINT=https://your-tenant.live.dynatrace.com
# Dynatrace platform/apps URL — used by the DQL query client in the test suite
# For live tenants:   https://your-tenant.apps.dynatrace.com
# For sprint tenants: https://your-tenant.sprint.apps.dynatracelabs.com
DT_APPS_ENDPOINT=https://your-tenant.apps.dynatrace.com
DT_API_TOKEN=dt0s16.YOUR_TOKEN   # OAuth token; required scopes:
                                  #   storage:events:read, storage:metrics:read, storage:metrics:write
                                  #   storage:spans:read, storage:buckets:read
                                  #   openpipeline:traces:ingest, openpipeline:metrics:ingest
                                  #   openpipeline:logs:ingest, openpipeline:events:ingest

# AWS credentials (required for aws-bedrock/* tests)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Limit LLM invocations per test run (default: 60; set to 1 for local debugging)
MAX_RUNS=1
