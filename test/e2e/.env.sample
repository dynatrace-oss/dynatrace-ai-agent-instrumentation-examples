# Dynatrace tenant (classic URL — used by OneAgent installer and OTel collector)
DT_ENDPOINT=https://your-tenant.live.dynatrace.com
# Dynatrace platform/apps URL — used by the DQL query client in the test suite
# For live tenants:   https://your-tenant.apps.dynatrace.com
# For sprint tenants: https://your-tenant.sprint.apps.dynatracelabs.com
DT_APPS_ENDPOINT=https://your-tenant.apps.dynatrace.com
DT_API_TOKEN=dt0s16.YOUR_TOKEN   # OAuth token; required scope: storage:query:read

# AWS credentials (required for aws-bedrock/* tests)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
