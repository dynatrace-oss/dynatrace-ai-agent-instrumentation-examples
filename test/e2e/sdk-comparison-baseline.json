      "rule_id": "AR-004",
      "required_level": "required",
      "group": "core-model",
      "providers": ["azure", "bedrock", "openai", "generic"],
      "owned_by": "framework_or_provider_sdk",
      "used_by": ["prompts_table", "distributed_tracing_intent", "onboarding_validation"]
    },
    {
      "name": "gen_ai.response.model",
      "rule_id": "AR-005",
      "required_level": "required",
      "group": "core-model",
      "providers": ["azure", "bedrock", "openai", "generic"],
      "owned_by": "framework_or_provider_sdk",
