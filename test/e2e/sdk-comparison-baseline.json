      "group": "agent",
      "providers": ["azure", "bedrock", "openai", "generic"],
      "owned_by": "framework_instrumentation",
      "used_by": ["agent_quick_filter", "overview_charts"],
      "note": "Used in if(isNotNull(gen_ai.agent.name), 'Agent', else: 'LLM') to classify spans."
    },
    {
